rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Standard helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Artisans
    match /artisans/{artisanId} {
      allow read: if true;
      allow write: if isAdmin();
      
      function isValidArtisan(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
               data.specialty is string &&
               data.bio is string;
      }
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artisan' && incoming().artisanId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'artisan' && existing().artisanId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Requests (Sur-mesure)
    match /requests/{requestId} {
      allow read: if isSignedIn() && (isOwner(existing().clientId) || isOwner(existing().artisanId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().clientId);
      allow update: if isSignedIn() && (isOwner(existing().artisanId) || isAdmin());
    }

    // Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users (to support role checks)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }
  }
}
